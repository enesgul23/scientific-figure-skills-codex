        "abbreviation_rules": [
          {"long": "root mean square error", "short": "RMSE", "allowed_roles": ["colorbar_title", "legend_label", "annotation"]},
          {"long": "discharge", "short": "Q", "allowed_roles": ["annotation", "colorbar_title"]}
        ],
        "forbidden_vague_labels": ["Map", "Spatial", "Value", "Index"],
        "caption_expansion_suggestions": [
          "Move long basemap, projection, and station-selection details into the caption."
