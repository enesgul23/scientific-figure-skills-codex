{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Project Visual Profile",
  "type": "object",
  "required": ["project_profile"],
  "properties": {
    "project_profile": {
      "type": "object",
      "required": ["project_id", "field", "preferred_language", "figure_style", "color_policy", "default_export", "created_at"],
      "properties": {
        "project_id": {"type": "string"},
        "field": {"type": "string"},
        "preferred_language": {"type": "string"},
        "target_journals": {"type": "array", "items": {"type": "string"}},
        "figure_style": {"type": "string"},
        "color_policy": {"type": "string"},
        "default_export": {"type": "array", "items": {"type": "string"}},
        "created_at": {"type": "string"},
        "updated_at": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
