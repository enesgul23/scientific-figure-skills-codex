        "abbreviation_rules": [
          {"long": "adjusted P value", "short": "adj. P", "allowed_roles": ["colorbar_title", "annotation"]},
          {"long": "false discovery rate", "short": "FDR", "allowed_roles": ["legend_label", "annotation"]}
        ],
        "forbidden_vague_labels": ["Genes", "Signal", "Expression level", "Significance"],
        "caption_expansion_suggestions": [
          "Define multiple-testing correction, feature-selection rule, and label-selection rule in the caption."
        ]
      },
      {
        "profile_id": "hydrology_time_series",
        "domains": ["hydrology-time-series", "hydrology", "time-series"],
        "chart_types": ["time_series_band", "hydrograph", "forecast_band"],
        "canonical_axis_labels": {
          "time": "Time",
          "discharge": "Discharge",
          "stage": "Water level",
          "precipitation": "Precipitation",
          "uncertainty": "Prediction interval"
        },
        "title_patterns": [
          "Observed and predicted discharge",
          "Hydrograph with prediction interval",
          "Forecast error over time"
        ],
        "unit_formatting": {
          "rule": "Use hydrologic units explicitly and keep time-zone information in the caption when needed.",
          "examples": ["Discharge (m^3/s)", "Precipitation (mm)", "Water level (m)"]
