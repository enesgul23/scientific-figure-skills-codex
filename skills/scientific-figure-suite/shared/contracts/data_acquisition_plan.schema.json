{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Scientific Figure Data Acquisition Plan",
  "type": "object",
  "required": ["data_acquisition_plan"],
  "properties": {
    "data_acquisition_plan": {
      "type": "object",
      "required": ["created_at", "decision", "approval_required", "download_allowed", "items", "risks", "blockers"],
      "properties": {
        "created_at": {"type": "string"},
        "chart_type": {"type": ["string", "null"]},
        "decision": {"enum": ["NOT_REQUIRED", "RECOMMENDED_WITH_APPROVAL", "BLOCKED_PENDING_SOURCE", "REJECTED"]},
        "approval_required": {"type": "boolean"},
        "download_allowed": {"type": "boolean"},
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["usage_role", "scientific_justification", "source_name", "source_url", "license", "citation", "status"],
            "properties": {
              "usage_role": {"enum": ["contextual", "evidentiary", "benchmark", "annotation"]},
              "data_kind": {"type": "string"},
              "scientific_justification": {"type": "string"},
              "source_name": {"type": ["string", "null"]},
              "source_url": {"type": ["string", "null"]},
              "license": {"type": ["string", "null"]},
              "citation": {"type": ["string", "null"]},
              "accessed_at": {"type": ["string", "null"]},
              "sha256": {"type": ["string", "null"]},
              "status": {"enum": ["planned", "needs_user_source", "ready_for_user_approval", "rejected"]},
              "contamination_risk": {"enum": ["none", "low", "medium", "high", "unknown"]}
            },
            "additionalProperties": true
          }
        },
        "risks": {"type": "array", "items": {"type": "string"}},
        "blockers": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
