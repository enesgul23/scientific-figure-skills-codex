{
  "profile_name": "universal_high_impact",
  "status": "ESTIMATED",
  "requires_live_verification": false,
  "figure_width_mm": {
    "single": 89,
    "double": 180
  },
  "font": {
    "preferred": ["Arial", "Helvetica"],
    "fallback": ["DejaVu Sans"]
  },
  "accessibility": {
    "minimum_font_size_pt": 6,
    "colorblind_safe": true,
    "palette": {
      "categorical": ["#0072B2", "#D55E00", "#009E73", "#CC79A7", "#E69F00"],
      "sequential": "viridis",
      "diverging": "cividis"
    }
  },
  "text_size_pt": {
    "minimum": 6,
    "preferred_min": 7,
    "preferred_max": 9
  },
  "panel_labels": {
    "case": "lowercase",
    "weight": "bold",
    "style": "upright"
  },
  "export": {
    "vector": ["pdf", "svg", "eps"],
    "raster": ["tiff", "png"],
    "min_dpi": 300
  },
  "avoid": [
    "3d_chart_effects",
    "rainbow_colormap",
    "red_green_only_contrast",
    "unsupported_dual_y_axis",
    "unlabelled_units",
    "missing_uncertainty"
  ]
}
