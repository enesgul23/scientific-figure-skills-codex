{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Visual Claim Ledger",
  "type": "object",
  "required": ["visual_claim_ledger"],
  "properties": {
    "visual_claim_ledger": {
      "type": "object",
      "required": ["figure_id", "data_status", "claims"],
      "properties": {
        "figure_id": {"type": "string"},
        "data_status": {"enum": ["PROVIDED", "INFERRED", "MISSING", "MOCKUP"]},
        "claims": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "claim_text", "claim_type", "visual_element", "support_status", "caption_alignment"],
            "properties": {
              "id": {"type": "string"},
              "claim_text": {"type": "string"},
              "claim_type": {"type": "string"},
              "visual_element": {"type": "string"},
              "support_status": {"enum": ["supported", "partially_supported", "unsupported", "unverifiable"]},
              "caption_alignment": {"type": "string"}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
