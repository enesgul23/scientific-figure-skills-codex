        "abbreviation_rules": [
          {"long": "discharge", "short": "Q", "allowed_roles": ["legend_label", "annotation", "colorbar_title"]},
          {"long": "prediction interval", "short": "PI", "allowed_roles": ["legend_label", "annotation"]}
        ],
        "forbidden_vague_labels": ["Flow", "Level", "Prediction", "Time series"],
        "caption_expansion_suggestions": [
          "State gauge, time zone, aggregation interval, and whether uncertainty is pointwise or simultaneous."
        ]
      }
    ]
  }
